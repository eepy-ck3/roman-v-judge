# ============================================================
# .env.example — Copy this to .env and fill in your values
# NEVER commit your actual .env to git (it's already in .gitignore)
# ============================================================

# ── Season ─────────────────────────────────────────────────────────────────────
SEASON=2025

# ── Player IDs ─────────────────────────────────────────────────────────────────
# MLB Stats API player IDs — verify yours at:
#   statsapi.mlb.com/api/v1/people/search?names=Roman+Anthony
#   statsapi.mlb.com/api/v1/people/search?names=Aaron+Judge
ROMAN_PLAYER_ID=701350
JUDGE_PLAYER_ID=592450

# MLB Team IDs (for schedule lookups)
ROMAN_TEAM_ID=111     # Boston Red Sox
JUDGE_TEAM_ID=147     # New York Yankees

# FanGraphs player IDs (for WAR + wRC+)
# Find yours at: fangraphs.com/players/{name} — look at ?playerid= in the URL
ROMAN_FANGRAPHS_ID=sa934320
JUDGE_FANGRAPHS_ID=15640

# ── Your Names ─────────────────────────────────────────────────────────────────
YOUR_NAME=Cole
BROTHER_NAME=Your Brother

# ── Notification Recipients ────────────────────────────────────────────────────
YOUR_EMAIL=your@email.com
BROTHER_EMAIL=brother@email.com
YOUR_PHONE=+15551234567      # E.164 format (with country code)
BROTHER_PHONE=+15559876543

# ── Twilio (SMS) ───────────────────────────────────────────────────────────────
# Sign up free at: twilio.com
# Console: console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15550000000   # Your Twilio phone number

# ── Gmail SMTP (Email) ────────────────────────────────────────────────────────
# IMPORTANT: Use an App Password, NOT your Gmail password
# How to get one: myaccount.google.com → Security → 2-Step Verification → App Passwords
# Create a custom app name like "Bet Tracker"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char Gmail App Password
EMAIL_FROM_NAME=Roman vs Judge Bet Tracker 🏆

# ── Odds API (MVP Futures) ────────────────────────────────────────────────────
# Free tier: the-odds-api.com (500 requests/month — more than enough with caching)
# If you don't have a key, leave blank and update odds manually via the dashboard
ODDS_API_KEY=your_odds_api_key_here

# Manual MVP odds fallback (American format — update anytime from the dashboard)
# Check DraftKings, FanDuel, or BetMGM for current futures odds
MANUAL_JUDGE_ODDS=+150
MANUAL_ROMAN_ODDS=+2500

# ── Scheduler Settings ────────────────────────────────────────────────────────
# When to send the weekly report (Eastern Time)
# Default: Monday at 8:00 AM ET
WEEKLY_REPORT_DAY=mon
WEEKLY_REPORT_HOUR=8
WEEKLY_REPORT_MINUTE=0

# ── App Settings ──────────────────────────────────────────────────────────────
PORT=8000
DEBUG=false

# Cache TTLs in seconds
CACHE_TTL_STATS=900        # 15 min — MLB data refreshes ~every 10 min during games
CACHE_TTL_SCHEDULE=3600    # 1 hour — schedules don't change much
CACHE_TTL_ODDS=21600       # 6 hours — odds don't move that fast
